AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__AUTH_MANAGER=airflow.providers.fab.auth_manager.fab_auth_manager.FabAuthManager
AIRFLOW__CORE__EXECUTION_API_SERVER_URL=http://airflow-webserver:8080/execution/
AIRFLOW__API_AUTH__JWT_SECRET=airflow_jwt_dev_secret_change_me
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://postgres:postgres@postgres:5432/airflow_hn
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://postgres:postgres@postgres:5432/airflow_hn
AIRFLOW__CORE__FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLbfzqDDho=
AIRFLOW__CORE__LOGGING_LEVEL=INFO
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__SCHEDULER__ENABLE_HEALTH_CHECK=true

# Task logs → S3 ([logging] section — NOT [core]. CORE__REMOTE_* is ignored.)
# REMOTE_LOG_CONN_ID = Airflow Connection id (Amazon Web Services / aws), same as S3Hook uses.
# REMOTE_BASE_LOG_FOLDER must start with s3://
# Docs: https://airflow.apache.org/docs/apache-airflow-providers-amazon/stable/logging/s3-task-handler.html
AIRFLOW__LOGGING__REMOTE_LOGGING=True
AIRFLOW__LOGGING__REMOTE_LOG_CONN_ID=AWSS3LogStorage
AIRFLOW__LOGGING__REMOTE_BASE_LOG_FOLDER=s3://hn-data-engineering/logs
AIRFLOW__LOGGING__ENCRYPT_S3_LOGS=False
# Set True to remove local copies after upload (see Airflow logging docs).
AIRFLOW__LOGGING__DELETE_LOCAL_LOGS=False
